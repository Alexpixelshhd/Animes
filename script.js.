// 1. Configuración básica
const API_BASE = 'https://api.jikan.moe/v4';
const container = document.getElementById('anime-container');
const searchInput = document.getElementById('search-input');

// 2. Función para obtener datos de la API
async function cargarAnimes(query = '') {
    // Si hay búsqueda, usamos el endpoint de búsqueda; si no, el de "top"
    const url = query 
        ? `${API_BASE}/anime?q=${query}&order_by=score&sort=desc&limit=12` 
        : `${API_BASE}/top/anime?limit=12`;

    try {
        container.innerHTML = '<p class="col-span-full text-center">Buscando en la base de datos...</p>';
        
        const response = await fetch(url);
        const data = await response.json();
        
        dibujarTarjetas(data.data);
    } catch (error) {
        console.error("Error en la petición:", error);
        container.innerHTML = '<p class="col-span-full text-center text-red-500">Error al conectar. Reintenta.</p>';
    }
}

// 3. Función para mostrar los animes en pantalla
function dibujarTarjetas(animes) {
    if (!animes || animes.length === 0) {
        container.innerHTML = '<p class="col-span-full text-center">No se encontraron resultados. 🧐</p>';
        return;
    }

    container.innerHTML = animes.map(anime => `
        <div class="bg-[#111625] rounded-2xl overflow-hidden border border-gray-800 shadow-lg">
            <img src="${anime.images.jpg.large_image_url}" class="w-full h-64 object-cover">
            <div class="p-4">
                <h3 class="font-bold text-white mb-2">${anime.title}</h3>
                <p class="text-xs text-gray-400 line-clamp-2 mb-4">${anime.synopsis || 'Sin descripción.'}</p>
                <a href="${anime.url}" target="_blank" class="block text-center bg-blue-600 py-2 rounded-lg text-sm font-bold">Ver más</a>
            </div>
        </div>
    `).join('');
}

// 4. Escuchar el buscador con un pequeño retraso (Debounce)
let tiempoEspera;
if (searchInput) {
    searchInput.addEventListener('input', (e) => {
        clearTimeout(tiempoEspera);
        const texto = e.target.value.trim();

        tiempoEspera = setTimeout(() => {
            if (texto.length > 2) {
                cargarAnimes(texto);
            } else if (texto.length === 0) {
                cargarAnimes(); // Vuelve al top si borras todo
            }
        }, 500);
    });
}

// 5. Carga inicial al abrir la página
cargarAnimes();
