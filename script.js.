// 1. CONFIGURACIÓN DE ELEMENTOS
// Usamos nombres que coincidan exactamente con tu HTML
const CONFIG = {
    gridId: 'main-grid',
    searchId: 'main-search',
    apiBase: 'https://api.jikan.moe/v4'
};

// 2. INICIO SEGURO
// Esperamos a que el navegador esté listo para evitar errores de "null"
document.addEventListener('DOMContentLoaded', () => {
    console.log("✅ Sistema Zenith iniciado");
    
    const grid = document.getElementById(CONFIG.gridId);
    const search = document.getElementById(CONFIG.searchId);

    if (!grid || !search) {
        console.error("❌ Error: No se encontraron los elementos en el HTML. Revisa los IDs.");
        return;
    }

    // Carga inicial (Top Animes)
    solicitarAnimes();

    // Configurar Buscador
    let timer;
    search.addEventListener('input', (e) => {
        clearTimeout(timer);
        const query = e.target.value.trim();
        
        timer = setTimeout(() => {
            if (query.length > 2) {
                solicitarAnimes(`/anime?q=${query}&limit=20`);
            } else if (query.length === 0) {
                solicitarAnimes();
            }
        }, 600);
    });
});

// 3. FUNCIÓN DE COMUNICACIÓN CON LA API
async function solicitarAnimes(endpoint = '/top/anime?limit=20') {
    const grid = document.getElementById(CONFIG.gridId);
    
    // Indicador de carga visual
    grid.innerHTML = '<div class="col-span-full text-center py-20 text-blue-400 animate-pulse">Conectando con la base de datos... 📡</div>';

    try {
        console.log(`📡 Solicitando: ${CONFIG.apiBase}${endpoint}`);
        const response = await fetch(`${CONFIG.apiBase}${endpoint}`);
        
        if (!response.ok) throw new Error(`Fallo en la red: ${response.status}`);

        const result = await response.json();
        console.log("📦 Datos recibidos:", result.data.length, "animes");

        dibujarInterfaz(result.data);

    } catch (error) {
        console.error("❌ Error en la carga:", error);
        grid.innerHTML = `
            <div class="col-span-full text-center py-20 text-red-500">
                <p class="text-2xl mb-2">🔌 Error de Conexión</p>
                <p class="text-sm opacity-70">${error.message}</p>
            </div>`;
    }
}

// 4. FUNCIÓN PARA PINTAR LAS TARJETAS
function dibujarInterfaz(animes) {
    const grid = document.getElementById(CONFIG.gridId);
    grid.innerHTML = ''; // Limpiar cargador

    if (animes.length === 0) {
        grid.innerHTML = '<p class="col-span-full text-center text-gray-500">No se encontraron resultados 🕵️‍♂️</p>';
        return;
    }

    animes.forEach(anime => {
        const card = document.createElement('div');
        card.className = "bg-slate-900 rounded-2xl overflow-hidden border border-slate-800 shadow-lg hover:border-blue-500 transition-all duration-300 p-2";
        
        card.innerHTML = `
            <img src="${anime.images.jpg.large_image_url}" class="w-full h-56 object-cover rounded-xl mb-3" alt="${anime.title}">
            <div class="p-2">
                <h3 class="font-bold text-sm truncate text-white mb-1">${anime.title}</h3>
                <div class="flex justify-between items-center mt-2">
                    <span class="text-[10px] bg-blue-600 px-2 py-0.5 rounded text-white font-black">⭐ ${anime.score || 'N/A'}</span>
                    <a href="${anime.url}" target="_blank" class="text-[10px] text-blue-400 hover:underline font-bold">VER MÁS</a>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });
}
