<script>
    // 1. Conexión con los elementos del HTML
    const gridAnimes = document.getElementById('grid-animes');
    const buscador = document.getElementById('buscador-principal');

    // 2. Función maestra para obtener datos de la API (Jikan v4)
    async function obtenerDatos(termino = '') {
        // Si hay texto busca por nombre, si no, trae el Top de la temporada
        const url = termino 
            ? `https://api.jikan.moe/v4/anime?q=${termino}&limit=12` 
            : `https://api.jikan.moe/v4/top/anime?limit=12`;

        try {
            const respuesta = await fetch(url);
            const resultado = await respuesta.json();
            dibujarPantalla(resultado.data);
        } catch (error) {
            console.error("Error de conexión:", error);
            gridAnimes.innerHTML = '<p class="col-span-full text-center text-red-500">Hubo un error al conectar con la base de datos. 🔌</p>';
        }
    }

    // 3. Función para "pintar" las tarjetas de anime
    function dibujarPantalla(lista) {
        gridAnimes.innerHTML = ''; // Limpiamos el mensaje de "Cargando"

        if (!lista || lista.length === 0) {
            gridAnimes.innerHTML = '<p class="col-span-full text-center">No encontramos nada con ese nombre. 🧐</p>';
            return;
        }

        lista.forEach(anime => {
            const tarjeta = `
                <div class="anime-card bg-[#1c2333] rounded-2xl overflow-hidden border border-gray-800 shadow-lg transition-all duration-300">
                    <img src="${anime.images.jpg.large_image_url}" class="w-full h-64 object-cover" alt="${anime.title}">
                    <div class="p-5">
                        <h3 class="font-bold text-lg mb-2 truncate text-blue-400">${anime.title}</h3>
                        <p class="text-xs text-gray-400 line-clamp-3 mb-4">${anime.synopsis || 'Sin descripción disponible.'}</p>
                        <a href="${anime.url}" target="_blank" class="block w-full text-center bg-blue-600 hover:bg-blue-500 py-2 rounded-xl font-bold text-sm transition-colors shadow-lg">
                            VER FICHA
                        </a>
                    </div>
                </div>
            `;
            gridAnimes.innerHTML += tarjeta;
        });
    }

    // 4. Lógica del buscador con retraso (Debounce)
    let temporizador;
    buscador.addEventListener('input', (e) => {
        clearTimeout(temporizador);
        const texto = e.target.value.trim();

        temporizador = setTimeout(() => {
            if (texto.length > 2) {
                obtenerDatos(texto);
            } else if (texto.length === 0) {
                obtenerDatos(); // Si borra todo, vuelve al Top
            }
        }, 500); // Espera 500ms para no saturar la API
    });

    // 5. Carga inicial al abrir la página
    obtenerDatos();
</script>
