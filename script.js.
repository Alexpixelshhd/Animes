// 1. Definimos la dirección de la base de datos
const API_URL = 'https://api.jikan.moe/v4/top/anime?limit=10';

// 2. Función para obtener los datos
async function obtenerPopulares() {
    console.log("Intentando conectar...");
    
    try {
        const respuesta = await fetch(API_URL); // Pedimos los datos
        const datos = await respuesta.json();   // Los convertimos a formato legible
        
        console.log("¡Datos recibidos!", datos.data);
        
        // Llamamos a la función que dibuja en pantalla
        mostrarEnPantalla(datos.data);
        
    } catch (error) {
        console.error("Hubo un error en la conexión:", error);
    }
}

// 3. Función para "pintar" los resultados en el HTML
function mostrarEnPantalla(listaAnimes) {
    const contenedor = document.getElementById('grilla-animes');
    contenedor.innerHTML = ''; // Limpiamos el mensaje de "Cargando..."

    listaAnimes.forEach(anime => {
        // Creamos una tarjeta básica para probar
        const tarjeta = `
            <div class="bg-slate-900 p-4 rounded-xl shadow-lg border border-slate-800">
                <img src="${anime.images.jpg.image_url}" class="w-full h-48 object-cover rounded-md mb-2">
                <h3 class="font-bold text-sm truncate">${anime.title}</h3>
                <p class="text-blue-400 text-xs mt-1">⭐ ${anime.score || 'N/A'}</p>
            </div>
        `;
        contenedor.innerHTML += tarjeta;
    });
}

// 4. Arrancamos el motor
obtenerPopulares();
