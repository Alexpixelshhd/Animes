/**
 * ZENITH ANIME PRO - CORE ENGINE ⚙️
 * Este script maneja la lógica de búsqueda, filtros y renderizado.
 */

// --- 1. CONFIGURACIÓN INICIAL ---
const API_BASE = 'https://api.jikan.moe/v4';
const grid = document.getElementById('main-grid');
const searchInput = document.getElementById('main-search');
const filterBtns = document.querySelectorAll('.filter-btn');

// --- 2. MOTOR DE DATOS (API) ---
async function cargarAnimes(endpoint = '/top/anime?limit=15') {
    // Mostramos un efecto de carga básico
    grid.innerHTML = '<p class="col-span-full text-center animate-pulse">Buscando en la base de datos... 🚀</p>';

    try {
        const response = await fetch(`${API_BASE}${endpoint}`);
        const data = await response.json();
        
        if (data.data) {
            renderizarTarjetas(data.data);
        } else {
            grid.innerHTML = '<p class="col-span-full text-center">No se encontraron resultados. 🕵️‍♂️</p>';
        }
    } catch (error) {
        console.error("Error de conexión:", error);
        grid.innerHTML = '<p class="col-span-full text-center text-red-500">Error al conectar con el servidor. 🔌</p>';
    }
}

// --- 3. RENDERIZADO DE INTERFAZ ---
function renderizarTarjetas(animes) {
    grid.innerHTML = ''; // Limpiar el contenedor

    animes.forEach(anime => {
        const card = `
            <div class="anime-card bg-slate-900 rounded-2xl overflow-hidden border border-slate-800 shadow-lg group">
                <div class="relative h-64 overflow-hidden">
                    <img src="${anime.images.jpg.large_image_url}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-slate-950 to-transparent">
                        <span class="text-xs font-bold bg-blue-600 px-2 py-1 rounded">⭐ ${anime.score || 'N/A'}</span>
                    </div>
                </div>
                <div class="p-4">
                    <h3 class="font-bold text-sm mb-2 line-clamp-1 text-blue-400">${anime.title}</h3>
                    <p class="text-[10px] text-slate-400 line-clamp-2 mb-4">${anime.synopsis || 'Sin descripción disponible.'}</p>
                    <a href="${anime.url}" target="_blank" class="block w-full text-center bg-slate-800 hover:bg-blue-600 py-2 rounded-lg text-[10px] font-bold transition-colors">
                        MÁS DETALLES
                    </a>
                </div>
            </div>
        `;
        grid.innerHTML += card;
    });
}

// --- 4. CONTROLADORES DE EVENTOS ---

// Lógica de Búsqueda (con retraso para no saturar la API)
let tiempoEspera;
searchInput.addEventListener('input', (e) => {
    clearTimeout(tiempoEspera);
    const query = e.target.value.trim();

    tiempoEspera = setTimeout(() => {
        if (query.length > 2) {
            cargarAnimes(`/anime?q=${query}&limit=15`);
        } else if (query.length === 0) {
            cargarAnimes(); // Volver al Top
        }
    }, 600);
});

// Lógica de Filtros por Género
filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
        // Estética: Cambiar botón activo
        filterBtns.forEach(b => b.classList.remove('bg-blue-600', 'shadow-lg'));
        btn.classList.add('bg-blue-600', 'shadow-lg');

        const genreId = btn.getAttribute('data-genre');
        if (genreId) {
            cargarAnimes(`/anime?genres=${genreId}&limit=15&order_by=score&sort=desc`);
        } else {
            cargarAnimes(); // Top / Tendencias
        }
    });
});

// --- 5. INICIO ---
cargarAnimes();
